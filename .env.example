# ============================================================
# US UK Accountants — environment configuration
# Copy to .env.local and fill in. All are optional for dev:
# the funnel works without them (forms log + show success).
# ============================================================

# --- Email notifications (Resend: https://resend.com) ---
# Without these, leads are logged to the server console instead of emailed.
RESEND_API_KEY=
LEAD_NOTIFY_TO=hello@usukaccountants.com
LEAD_NOTIFY_FROM="US UK Accountants <hello@usukaccountants.com>"

# --- Booking scheduler (pick ONE; falls back to in-house form if neither set) ---
# Cal.com: the part after cal.com/ in your booking link
NEXT_PUBLIC_CALCOM_LINK=
# Calendly: full inline-widget URL
NEXT_PUBLIC_CALENDLY_URL=

# --- Analytics (GA4) ---
# Without this, analytics calls are no-ops (no GA script loads).
NEXT_PUBLIC_GA_ID=
